# PRODUCTION DEPLOYMENT WORKFLOW
# This is the REAL deployment workflow - use this once secrets are configured
# 
# TO ACTIVATE:
# 1. Add secrets to GitHub: VERCEL_TOKEN, VERCEL_ORG_ID, VERCEL_PROJECT_ID
# 2. Rename this file to: deploy.yml
# 3. Delete the current deploy.yml (placeholder version)
#
# HOW TO GET SECRETS:
# - VERCEL_TOKEN: https://vercel.com/account/tokens
# - VERCEL_ORG_ID & VERCEL_PROJECT_ID: Run `vercel link` in client folder, check .vercel/project.json

name: Deploy Pipeline

on:
  push:
    branches: [ main ]
  workflow_dispatch:

jobs:
  # CI must pass before deployment
  ci:
    name: CI Check
    runs-on: ubuntu-latest
    
    steps:
      - name: Checkout code
        uses: actions/checkout@v4
      
      - name: Run CI test
        run: echo "✅ CI passed - ready to deploy"

  # Deploy frontend to Vercel
  deploy-frontend:
    name: Deploy Frontend to Vercel
    runs-on: ubuntu-latest
    needs: ci  # Only run if CI passes
    
    steps:
      - name: Checkout code
        uses: actions/checkout@v4
      
      - name: Setup Node.js
        uses: actions/setup-node@v4
        with:
          node-version: '18'
      
      - name: Install Vercel CLI
        run: npm install -g vercel@latest
      
      - name: Pull Vercel Environment
        working-directory: ./client
        run: vercel pull --yes --environment=production --token=${{ secrets.VERCEL_TOKEN }}
        env:
          VERCEL_ORG_ID: ${{ secrets.VERCEL_ORG_ID }}
          VERCEL_PROJECT_ID: ${{ secrets.VERCEL_PROJECT_ID }}
      
      - name: Build Project
        working-directory: ./client
        run: vercel build --prod --token=${{ secrets.VERCEL_TOKEN }}
        env:
          VERCEL_ORG_ID: ${{ secrets.VERCEL_ORG_ID }}
          VERCEL_PROJECT_ID: ${{ secrets.VERCEL_PROJECT_ID }}
      
      - name: Deploy to Vercel
        id: deploy
        working-directory: ./client
        run: |
          DEPLOYMENT_URL=$(vercel deploy --prebuilt --prod --token=${{ secrets.VERCEL_TOKEN }})
          echo "url=$DEPLOYMENT_URL" >> $GITHUB_OUTPUT
          echo "✅ Deployed to: $DEPLOYMENT_URL"
        env:
          VERCEL_ORG_ID: ${{ secrets.VERCEL_ORG_ID }}
          VERCEL_PROJECT_ID: ${{ secrets.VERCEL_PROJECT_ID }}
      
      - name: Deployment Summary
        run: |
          echo "### 🚀 Deployment Successful!" >> $GITHUB_STEP_SUMMARY
          echo "" >> $GITHUB_STEP_SUMMARY
          echo "**URL:** ${{ steps.deploy.outputs.url }}" >> $GITHUB_STEP_SUMMARY
          echo "**Commit:** ${{ github.sha }}" >> $GITHUB_STEP_SUMMARY
          echo "**Branch:** ${{ github.ref_name }}" >> $GITHUB_STEP_SUMMARY

  # Optional: Deploy backend (if needed)
  deploy-backend:
    name: Deploy Backend (Optional)
    runs-on: ubuntu-latest
    needs: ci
    if: false  # Set to true to enable backend deployment
    
    steps:
      - name: Checkout code
        uses: actions/checkout@v4
      
      - name: Backend deployment placeholder
        run: |
          echo "Backend deployment can be configured here"
          echo "Options: Railway, Heroku, Docker, etc."
